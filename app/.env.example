DATABRICKS_HOST=https://dbc-ad78fc43-bcc0.cloud.databricks.com

# matches a profile in ~/.databrickscfg
DATABRICKS_CONFIG_PROFILE=databricks-cli

DATABRICKS_WAREHOUSE_ID=4501ae4095de396a

# Unity Catalog catalog name
DQX_CATALOG=dqx
 
 # schema inside the catalog
DQX_SCHEMA=dqx_studio

# required for profiler/dry-run
DQX_JOB_ID=dqx-studio-task-runner

# UC volume path; auto-set by DABs in production
DQX_WHEELS_VOLUME=/Volumes/dqx/dqx_studio/wheels

# workspace group granted bootstrap Admin access
DQX_ADMIN_GROUP=admins

# Lakebase (optional — leave DQX_LAKEBASE_INSTANCE_NAME empty to run OLTP tables on Delta locally)
DQX_LAKEBASE_INSTANCE_NAME=postgresql.sandbox.net

#
DQX_LAKEBASE_PG_URL=postgresql://postgres:paSSW0rd@postgresql.sandbox.net:5432/databricks_postgres?sslmode=disable

# logical Postgres DB; defaults to the always-present admin DB
DQX_LAKEBASE_DATABASE_NAME=databricks_postgres

# Postgres schema (default: dqx_studio)
DQX_LAKEBASE_SCHEMA=builder_app

# psycopg connection pool floor
DQX_LAKEBASE_POOL_MIN_SIZE=1

# psycopg connection pool ceiling
DQX_LAKEBASE_POOL_MAX_SIZE=10

# OAuth token refresh cadence (token expires at 60)
DQX_LAKEBASE_TOKEN_REFRESH_MINUTES=50